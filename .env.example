# ============================================================
# Konfigurasi Lingkungan (Environment Variables)
# ============================================================
# Salin file ini ke .env dan isi dengan data yang sesuai.
# JANGAN commit .env ke repository!

# Token Bot Telegram dari @BotFather
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# KlikQRIS API Key (Sandbox)
KLIKQRIS_API_KEY=YOUR_SANDBOX_API_KEY_HERE

# KlikQRIS Merchant ID
KLIKQRIS_MERCHANT_ID=YOUR_MERCHANT_ID_HERE

# Mode: sandbox atau production
KLIKQRIS_MODE=sandbox

# Admin Telegram User ID (dapatkan dari @userinfobot)
ADMIN_USER_ID=123456789

# Webhook URL (untuk callback pembayaran)
WEBHOOK_URL=https://your-domain.com/webhook

# Webhook Port (default: 8443)
WEBHOOK_PORT=8443

# Path ke file konfigurasi
CONFIG_PATH=config.yaml

# URL PostgreSQL (opsional, kosongkan untuk pakai SQLite)
DATABASE_URL=

# Path ke database SQLite
DATABASE_PATH=data/bot.db
