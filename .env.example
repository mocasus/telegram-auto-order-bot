# ============================================================
# Simpel Order Bot — Template Environment
# Salin file ini ke .env lalu isi nilai yang kosong.
# ============================================================

# Token Bot Telegram dari @BotFather
TELEGRAM_BOT_TOKEN=
# User ID admin Telegram (dapatkan dari @userinfobot)
ADMIN_USER_ID=

# Info pembayaran manual (fallback jika KlikQRIS non-aktif)
PAYMENT_BANK=BCA
PAYMENT_NUMBER=123-456-789
PAYMENT_NAME=Moca

# Nama toko
SHOP_NAME=Toko Moca

# Lokasi database SQLite
DB_PATH=data/bot.db

# ============================================================
# KlikQRIS Payment Gateway (opsional)
# Daftar gratis di https://klikqris.com (ada mode sandbox)
# Kalau kosong, bot fallback ke info transfer manual di atas.
# ============================================================
# API Key dari dashboard KlikQRIS
KLIKQRIS_API_KEY=
# Merchant ID dari dashboard KlikQRIS
KLIKQRIS_MERCHANT_ID=

# Mode: sandbox (testing) | production (transaksi nyata)
KLIKQRIS_MODE=sandbox
